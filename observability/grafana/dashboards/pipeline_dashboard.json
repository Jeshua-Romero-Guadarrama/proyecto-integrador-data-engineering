{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Pipeline de Ventas — Observabilidad",
  "tags": ["dataeng", "ventas"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Última corrida exitosa",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } },
      "targets": [
        { "expr": "ventas_pipeline_ultimo_exito_timestamp * 1000", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Duración (s)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "ventas_pipeline_duracion_segundos", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Ingreso total procesado",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [{ "expr": "ventas_pipeline_ingreso_total", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Chequeos de calidad (ok/fallidos)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "ventas_pipeline_chequeos_ok", "refId": "A", "legendFormat": "ok" },
        { "expr": "ventas_pipeline_chequeos_fallidos", "refId": "B", "legendFormat": "fallidos" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Filas de entrada vs salida",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "ventas_pipeline_filas_entrada", "refId": "A", "legendFormat": "filas_entrada" },
        { "expr": "ventas_pipeline_filas_salida", "refId": "B", "legendFormat": "filas_salida" }
      ]
    }
  ]
}
